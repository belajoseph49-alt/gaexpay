# ============================================================
# GaexPay — Environment Variables (Production Template)
# ============================================================
# Copy to `.env` and fill in real values. NEVER commit the real `.env`.
# Dev defaults to SQLite (see prisma/schema.prisma); production should
# target PostgreSQL (see prisma/schema.postgres.prisma).
# ============================================================

# ---- Database (PostgreSQL for production) -----------------
DATABASE_URL="postgresql://gaexpay:password@localhost:5432/gaexpay?schema=public"
DIRECT_URL="postgresql://gaexpay:password@localhost:5432/gaexpay?schema=public"

# For local SQLite dev, override with:
# DATABASE_URL="file:/home/z/my-project/db/custom.db"

# ---- Security ---------------------------------------------
GAEXPAY_JWT_SECRET=""        # 32+ char hex string (openssl rand -hex 32)
GAEXPAY_ENC_KEY=""           # 32+ char hex string for AES-256-GCM
GXP_CARD_KEK=""              # Key Encryption Key for card numbers

# ---- Auth -------------------------------------------------
GXP_ALLOW_DEV_AUTH=false     # NEVER true in production
GXP_ACCESS_TOKEN_TTL=900     # 15 minutes
GXP_REFRESH_TOKEN_TTL=604800 # 7 days

# ---- SMTP (LWS Mail) --------------------------------------
SMTP_HOST=mail.gaexpay.com
SMTP_PORT=465
SMTP_USER=noreply@gaexpay.com
SMTP_PASS=
SMTP_FROM=GaexPay <noreply@gaexpay.com>

# ---- Redis (for rate limiting) ----------------------------
REDIS_URL=

# ---- OAuth ------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ---- Allowed Origins (CORS) -------------------------------
GXP_ALLOWED_ORIGINS=https://gaexpay.com,https://admin.gaexpay.com

# ---- Sentry -----------------------------------------------
SENTRY_DSN=

# ---- Paystack ---------------------------------------------
PAYSTACK_SECRET_KEY=
PAYSTACK_PUBLIC_KEY=
