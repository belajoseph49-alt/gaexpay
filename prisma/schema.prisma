// GaexPay - Fintech platform database schema
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String   @id @default(cuid())
  email           String   @unique
  phone           String   @unique
  passwordHash    String
  firstName       String
  lastName        String
  username        String?  @unique
  avatar          String?
  country         String   @default("Nigeria")
  city            String?
  address         String?
  dob             String?
  gender          String?

  // KYC
  kycStatus       String   @default("unverified") // unverified | pending | verified | rejected
  kycTier         Int      @default(0) // 0, 1, 2, 3
  kycSubmittedAt  DateTime?
  kycVerifiedAt   DateTime?
  kycRejectionReason String?

  // Security
  mfaEnabled      Boolean  @default(false)
  mfaSecret       String?
  biometricEnabled Boolean @default(false)
  twoFactorMethod String?  // authenticator | sms | email
  pinHash         String?

  // Preferences
  language        String   @default("en")
  currency        String   @default("NGN")
  themePreference String   @default("system") // light | dark | system
  emailNotif      Boolean  @default(true)
  pushNotif       Boolean  @default(true)
  smsNotif        Boolean  @default(false)

  // Status
  status          String   @default("active") // active | suspended | frozen | closed
  role            String   @default("user") // user | admin | agent | support | super_admin | moderator | financial_manager | kyc_manager | marketplace_manager | content_manager
  lastLoginAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Account type & RBAC
  accountType     String   @default("personal") // personal | business
  permissions     String   @default("[]") // JSON array of permission strings (granular RBAC)

  // Password reset
  resetToken      String?
  resetTokenExpiry DateTime?

  wallets         Wallet[]
  transactions    Transaction[] @relation("TxUser")
  transactionsOut Transaction[] @relation("TxSender")
  cards           Card[]
  beneficiaries   Beneficiary[]
  notifications   Notification[]
  supportTickets  SupportTicket[]
  supportMessages SupportMessage[]
  auditLogs       AuditLog[]
  devices         Device[]
  referralCode    String?  @unique
  referredById    String?
  referralEarnings Float   @default(0)
  referralCount   Int      @default(0)
  rewardPoints    Int      @default(0)
  kycDocuments    KycDocument[]
  businessProfile BusinessProfile?
  achievements    UserAchievement[]

  // MiniPay feature gap — reverse relations
  cashLinksCreated   CashLink[] @relation("CashLinkCreator")
  cashLinksClaimed   CashLink[] @relation("CashLinkClaimant")
  virtualAccounts    VirtualAccount[]
  holdEarnRecords    HoldEarnRecord[]
  travelDestinations TravelWalletDestination[]
  esimPurchases      ESimPurchase[]
  pockets            Pocket[]

  // Savings Challenges (gamified savings)
  challengeParticipations UserChallengeParticipation[]

  // GaexChat — social messaging
  conversationsA         Conversation[] @relation("ConvParticipantA")
  conversationsB         Conversation[] @relation("ConvParticipantB")
  messages               Message[]
  paymentRequestsMade    PaymentRequest[] @relation("PaymentRequestRequester")
  paymentRequestsOwed    PaymentRequest[] @relation("PaymentRequestPayer")
  billSplitsInitiated    ChatBillSplit[] @relation("ChatBillSplitInitiator")
  billSplitShares        ChatBillSplitShare[] @relation("ChatBillSplitShareUser")
  chatGroupsCreated      ChatGroup[] @relation("ChatGroupCreator")
  chatGroupMemberships   ChatGroupMember[] @relation("ChatGroupMemberUser")
}

model Wallet {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency     String   // NGN, USD, EUR, GBP, GHS, KES, UGX, XOF
  balance      Float    @default(0)
  ledgerBalance Float   @default(0)
  type         String   @default("primary") // primary | savings | business
  label        String   @default("Main Wallet")
  isDefault    Boolean  @default(false)
  status       String   @default("active") // active | frozen | closed
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, currency, type])
}

model Transaction {
  id              String   @id @default(cuid())
  reference       String   @unique
  userId          String
  user            User     @relation("TxUser", fields: [userId], references: [id], onDelete: Cascade)
  senderId        String?
  sender          User?    @relation("TxSender", fields: [senderId], references: [id])
  type            String   // transfer | deposit | withdrawal | payment | bill | airtime | exchange | card | referral | fee
  direction       String   // credit | debit
  status          String   @default("pending") // pending | completed | failed | reversed | flagged
  amount          Float
  fee             Float    @default(0)
  currency        String   @default("NGN")
  description     String
  category        String   @default("general") // general | p2p | bills | shopping | travel | food | income | investment
  counterpartyName String?
  counterpartyAccount String?
  counterpartyBank String?
  method          String?  // wallet | momo | bank | card | qr | airtime
  provider        String?  // mtn | orange | airtel | moov | access | gtbank
  walletId        String?
  riskScore       Float    @default(0)
  fraudFlag       Boolean  @default(false)
  metadata        String?
  createdAt       DateTime @default(now())
  completedAt     DateTime?

  // GaexChat — financial actions linked from chat
  chatPaymentRequests  PaymentRequest[]     @relation("PaymentRequestTransaction")
  chatBillSplitShares  ChatBillSplitShare[] @relation("ChatBillSplitShareTransaction")
}

model Card {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String   // virtual | physical
  brand         String   // visa | mastercard | verve
  nickname      String   @default("GaexPay Card")
  maskedNumber  String
  fullNumberEnc String
  expiryMonth   String
  expiryYear    String
  cvvEnc        String
  holderName    String
  currency      String   @default("NGN")
  balance       Float    @default(0)
  limit         Float    @default(500000)
  spending      Float    @default(0)
  status        String   @default("active") // active | frozen | blocked
  color         String   @default("emerald")
  isDefault     Boolean  @default(false)
  createdAt     DateTime @default(now())
}

model Beneficiary {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name      String
  account   String
  bank      String?
  type      String   @default("bank") // bank | momo | wallet | gaexpay
  provider  String?
  currency  String   @default("NGN")
  email     String?
  phone     String?
  avatar    String?
  createdAt DateTime @default(now())
}

model KycDocument {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // national_id | passport | drivers_license | voters_card | utility_bill | selfie
  documentNumber String?
  frontImage String?
  backImage  String?
  selfieImage String?
  status    String   @default("pending") // pending | approved | rejected
  reviewedBy String?
  reviewNote String?
  createdAt DateTime @default(now())
  reviewedAt DateTime?
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  message   String
  type      String   @default("info") // info | success | warning | error | transaction | security | promo
  channel   String   @default("push") // push | email | sms | in_app
  isRead    Boolean  @default(false)
  actionUrl String?
  metadata  String?
  createdAt DateTime @default(now())
}

model SupportTicket {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  subject   String
  category  String   @default("general") // general | transaction | card | kyc | security | account
  priority  String   @default("medium") // low | medium | high | urgent
  status    String   @default("open") // open | in_progress | resolved | closed
  assignedTo String?
  messages  SupportMessage[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model SupportMessage {
  id        String   @id @default(cuid())
  ticketId  String
  ticket    SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  senderType String  @default("user") // user | agent | ai | system
  content   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  actor     String   @default("system")
  action    String
  entity    String
  entityId  String?
  ip        String?
  userAgent String?
  details   String?
  severity  String   @default("info") // info | warning | critical
  createdAt DateTime @default(now())
}

model Device {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name       String
  type       String   // mobile | desktop | tablet | web
  os         String?
  browser    String?
  location   String?
  ip         String?
  trusted    Boolean  @default(false)
  lastActive DateTime @default(now())
  createdAt  DateTime @default(now())
}

model ExchangeRate {
  id        String   @id @default(cuid())
  base      String
  quote     String
  rate      Float
  buy       Float
  sell      Float
  source    String   @default("internal")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([base, quote])
}

model Merchant {
  id        String   @id @default(cuid())
  name      String
  category  String   @default("retail") // retail | food | transport | utilities | entertainment | health
  logo      String?
  qrCode    String   @unique
  account   String
  phone     String?
  email     String?
  status    String   @default("active") // pending | approved | active | suspended | rejected
  rating    Float    @default(4.5)
  // Admin/Platform fields
  ownerName String?
  volume    Float    @default(0)
  qrCount   Int      @default(1)
  rejectionReason String?
  approvedAt DateTime?
  approvedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt
}

model Biller {
  id        String   @id @default(cuid())
  name      String
  category  String   // electricity | water | internet | tv | education | betting | government
  logo      String?
  fields    String   // JSON of required fields
  status    String   @default("active")
  createdAt DateTime @default(now())
}

model AdminMetric {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Float
  label     String
  category  String   @default("general")
  updatedAt DateTime @updatedAt
}

model SavingsGoal {
  id          String   @id @default(cuid())
  userId      String
  name        String
  targetAmount Float
  currentAmount Float @default(0)
  currency    String   @default("NGN")
  deadline    DateTime?
  icon        String   @default("🎯")
  color       String   @default("emerald")
  status      String   @default("active") // active | completed | paused
  autoSaveAmount Float?
  autoSaveDay  Int?    // day of month for auto-save
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  contributions SavingsContribution[]
}

model SavingsContribution {
  id        String   @id @default(cuid())
  goalId    String
  goal      SavingsGoal @relation(fields: [goalId], references: [id], onDelete: Cascade)
  amount    Float
  type      String   @default("deposit") // deposit | withdrawal
  note      String?
  createdAt DateTime @default(now())
}

model Budget {
  id         String   @id @default(cuid())
  userId     String
  category   String   // p2p | bills | shopping | food | transport | entertainment | general
  limit      Float
  spent      Float    @default(0)
  period     String   @default("monthly") // weekly | monthly
  currency   String   @default("NGN")
  alertThreshold Float @default(80)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model ScheduledTransfer {
  id         String   @id @default(cuid())
  userId     String
  recipientName String
  recipientAccount String?
  recipientBank  String?
  method     String   @default("wallet")
  provider   String?
  amount     Float
  currency   String   @default("NGN")
  note       String?
  frequency  String   // once | daily | weekly | monthly
  nextRunAt  DateTime
  lastRunAt  DateTime?
  status     String   @default("active") // active | paused | completed | failed
  totalRuns  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Dispute {
  id            String   @id @default(cuid())
  userId        String
  transactionId String
  transactionRef String
  reason        String   // unauthorized | failed_not_received | wrong_amount | duplicate | merchant_issue | other
  description   String
  status        String   @default("open") // open | under_review | resolved | rejected | refunded
  priority      String   @default("medium") // low | medium | high
  resolution    String?
  resolvedAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// ============================================================
// Business Profile (KYB — Know Your Business)
// ============================================================
model BusinessProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Company info
  companyName       String
  companyType       String?  // LLC | corporation | partnership | sole_proprietor | other
  registrationNumber String?
  taxId             String?
  commercialRegistry String?
  legalAddress      String?
  legalCity         String?
  legalCountry      String?
  website           String?
  industry          String?

  // Directors & beneficial owners (JSON)
  directors         String   @default("[]") // JSON array of {name, idNumber, role, dob}
  beneficialOwners  String   @default("[]") // JSON array of {name, idNumber, ownershipPercent, dob}

  // Documents (JSON array of {type, url, uploadedAt, verified})
  documents         String   @default("[]")

  // KYB status
  kybStatus         String   @default("unverified") // unverified | pending | verified | rejected
  kybSubmittedAt    DateTime?
  kybVerifiedAt     DateTime?
  kybRejectionReason String?
  kybTier           Int      @default(0)

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// ============================================================
// Centralized API configuration management
// ============================================================
model ApiConfig {
  id          String   @id @default(cuid())
  service     String   // payment | blockchain | kyc | kyb | sms | email | push | geolocation | ai | exchange_rate | cloud_storage | auth | other
  name        String   // human-readable name e.g. "Stripe", "CoinGecko", "Twilio SMS"
  provider    String?  // e.g. "stripe", "coingecko", "twilio"

  // Credentials (JSON — stores apiKey, secret, endpoint, etc.)
  credentials String   @default("{}") // JSON object

  // Configuration
  baseUrl     String?
  webhookUrl  String?
  environment String   @default("sandbox") // sandbox | production

  // Status
  enabled     Boolean  @default(false)
  isDefault   Boolean  @default(false)

  // Rate limits
  rateLimitPerMin Int?
  rateLimitPerDay Int?

  // Metadata
  description String?
  category    String?  // grouping for UI
  icon        String?

  // Monitoring
  lastUsedAt  DateTime?
  lastErrorAt DateTime?
  lastError   String?
  totalRequests Int    @default(0)
  failedRequests Int   @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  logs        ApiLog[]

  @@index([service, enabled])
}

// API request/error logs (per ApiConfig)
model ApiLog {
  id          String   @id @default(cuid())
  apiConfigId String
  apiConfig   ApiConfig @relation(fields: [apiConfigId], references: [id], onDelete: Cascade)

  level       String   // info | warn | error
  message     String
  endpoint    String?
  statusCode  Int?
  responseTimeMs Int?
  requestBody String?  // JSON (sanitized — no secrets)
  responseBody String? // JSON (truncated)

  createdAt   DateTime @default(now())

  @@index([apiConfigId, createdAt])
  @@index([level, createdAt])
}

// ============================================================
// Feature flags — toggle platform modules/features on/off
// ============================================================
model FeatureFlag {
  id          String   @id @default(cuid())
  key         String   @unique // e.g. "crypto_trading", "pi_network", "international_transfer"
  name        String
  description String?
  enabled     Boolean  @default(true)

  // Visibility — which account types/roles see this feature
  accountTypes String  @default("[\"personal\",\"business\"]") // JSON array
  roles       String   @default("[\"user\",\"admin\"]") // JSON array

  // Category for grouping in admin UI
  category    String   @default("general") // payments | crypto | security | communication | analytics | other

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// System settings — platform-wide key/value configuration
// (general settings, AML rules, templates, KYC tier configs,
// transfer corridors, treasury wallets, compliance reports, etc.)
// Complex values are stored as JSON strings.
// ============================================================
model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String   @default("")
  category  String   @default("general")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// ============================================================
// Fee configuration (configurable fees/commissions)
// ============================================================
model FeeConfig {
  id          String   @id @default(cuid())
  name        String   @unique // e.g. "transfer_fee", "crypto_swap_fee", "bill_payment_fee"
  description String?

  // Fee structure
  feeType     String   @default("percentage") // percentage | fixed | mixed
  feeValue    Float    @default(0) // percentage (0-100) or fixed amount
  fixedFee    Float    @default(0) // for mixed type
  currency    String   @default("NGN")

  // Limits
  minFee      Float    @default(0)
  maxFee      Float?
  minAmount   Float?
  maxAmount   Float?

  // Applicability
  transactionType String? // transfer | exchange | crypto_trade | bill | card | etc.
  accountType String  @default("all") // all | personal | business

  enabled     Boolean  @default(true)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ============================================================
// Achievement definitions & user unlocks (gamification)
// ============================================================
model Achievement {
  id            String   @id @default(cuid())
  code          String   @unique // e.g. "first_send", "tx_100", "referral_10"
  name          String
  description   String
  icon          String   @default("🏆")
  category      String   @default("general") // onboarding | transactions | volume | social | savings | wallets | security | milestone
  rewardPoints  Int      @default(0)
  targetCount   Int      @default(1)
  enabled       Boolean  @default(true)
  rarity        String   @default("common") // common | rare | epic | legendary
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  unlocks       UserAchievement[]
}

model UserAchievement {
  id            String   @id @default(cuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([achievementId])
}

// ============================================================
// Developer Portal — apps, API keys, webhooks
// ============================================================
model DeveloperApp {
  id            String   @id @default(cuid())
  name          String
  description   String?
  developerId   String
  developerName String
  developerEmail String?
  type          String   @default("web") // web | mobile | backend | integration | plugin
  status        String   @default("active") // active | suspended | deleted
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  apiKeys       DeveloperApiKey[]
  webhooks      Webhook[]
}

model DeveloperApiKey {
  id            String   @id @default(cuid())
  appId         String
  app           DeveloperApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  developerId   String
  developerName String
  keyPrefix     String   // first 8 chars (e.g. "gxp_live_")
  keyMasked     String   // e.g. gxp_live_abcd••••••wxyz
  keyHash       String   @unique // sha256 hash of full key for lookup
  scopes        String   @default("[]") // JSON array of scope strings
  status        String   @default("active") // active | revoked
  lastUsedAt    DateTime?
  createdAt     DateTime @default(now())
  revokedAt     DateTime?
  revokedReason String?

  @@index([developerId])
}

model Webhook {
  id            String   @id @default(cuid())
  appId         String
  app           DeveloperApp @relation(fields: [appId], references: [id], onDelete: Cascade)
  developerId   String
  developerName String
  url           String
  events        String   @default("[]") // JSON array of event types
  secretMasked  String?
  status        String   @default("active") // active | disabled | failing
  lastDeliveryAt DateTime?
  lastStatus    String? // success | failed | pending
  lastStatusCode Int?
  successRate   Float    @default(100)
  totalDelivered Int     @default(0)
  failedDelivered Int    @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([developerId])
}

// ============================================================
// Double-Entry Ledger — accounts, entries, balances
// (atomic, auditable money movement). Float in SQLite for dev;
// Decimal(18,4) in PostgreSQL (see schema.postgres.prisma).
// ============================================================
model LedgerAccount {
  id        String   @id @default(cuid())
  userId    String?
  walletId  String?
  type      String   // user-wallet | fee-revenue | float | tax | suspense | treasury
  currency  String
  code      String   @unique // e.g., "WALLET-{userId}-{currency}" or "FEE-NGN"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  entries   LedgerEntry[]
  balance   LedgerBalance?

  @@index([userId])
  @@index([type, currency])
  @@index([walletId])
}

model LedgerEntry {
  id            String   @id @default(cuid())
  accountId     String
  account       LedgerAccount @relation(fields: [accountId], references: [id])
  transactionId String?
  debit         Float    @default(0) // Decimal in PostgreSQL
  credit        Float    @default(0) // Decimal in PostgreSQL
  currency      String
  createdAt     DateTime @default(now())

  @@index([accountId, createdAt])
  @@index([transactionId])
}

model LedgerBalance {
  id        String   @id @default(cuid())
  accountId String   @unique
  account   LedgerAccount @relation(fields: [accountId], references: [id])
  currency  String
  balance   Float    @default(0) // Decimal in PostgreSQL
  updatedAt DateTime @updatedAt

  @@index([currency])
}

// ============================================================
// Idempotency — replay-safe API request cache
// ============================================================
model IdempotencyRecord {
  id           String   @id @default(cuid())
  key          String   @unique
  userId       String
  endpoint     String
  requestBody  String
  responseHash String
  statusCode   Int
  createdAt    DateTime @default(now())
  expiresAt    DateTime

  @@index([key])
  @@index([userId])
  @@index([expiresAt])
}

// ============================================================
// Refresh tokens — rotating, revocable JWT refresh tokens
// ============================================================
model RefreshToken {
  id          String    @id @default(cuid())
  userId      String
  token       String    @unique
  rotatedFrom String?
  revokedAt   DateTime?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime

  @@index([userId])
  @@index([token])
  @@index([rotatedFrom])
}

// ============================================================
// Sessions — server-tracked sessions with JTI + device binding
// ============================================================
model Session {
  id        String   @id @default(cuid())
  userId    String
  jti       String   @unique
  deviceFingerprint String?
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  expiresAt DateTime
  revokedAt DateTime?

  @@index([userId])
  @@index([jti])
  @@index([expiresAt])
}

// ============================================================
// MiniPay Feature Gap Models — Task minipay-1
// Cash Links, Virtual Accounts, Hold & Earn, Travel Wallet,
// Mini Apps, eSim, Pockets
// ============================================================

model CashLink {
  id           String   @id @default(cuid())
  token        String   @unique
  userId       String   // creator
  user         User     @relation("CashLinkCreator", fields: [userId], references: [id], onDelete: Cascade)
  claimantId   String?  // who claimed
  claimant     User?    @relation("CashLinkClaimant", fields: [claimantId], references: [id])
  amount       Float
  currency     String   @default("USD")
  note         String?
  status       String   @default("pending") // pending | claimed | expired | cancelled
  expiresAt    DateTime
  claimedAt    DateTime?
  createdAt    DateTime @default(now())

  @@index([userId])
  @@index([status])
}

model VirtualAccount {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  currency      String   // USD | EUR | GBP
  accountType   String   // checking | freelancer | business
  accountNumber String
  routingNumber String?  // for USD (ACH)
  iban          String?  // for EUR
  bic           String?  // SWIFT/BIC for EUR
  bankName      String
  bankAddress   String?
  holderName    String
  status        String   @default("active")
  createdAt     DateTime @default(now())

  @@index([userId])
  @@unique([userId, currency])
}

model HoldEarnRecord {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date            DateTime @default(now())
  eligibleBalance Float
  dailyReward     Float
  weeklyRate      Float    // e.g. 0.02 = 2%
  autoCompound    Boolean  @default(false)

  @@index([userId, date])
}

model TravelWalletDestination {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  countryCode     String
  countryName     String
  flag            String
  currency        String
  exchangeRate    Float
  lockedRate      Float?   // when locked, this is the frozen rate
  rateLockedUntil DateTime?
  budget          Float?
  spent           Float    @default(0)
  status          String   @default("active") // active | completed | archived
  createdAt       DateTime @default(now())

  @@index([userId])
  @@unique([userId, countryCode])
}

model MiniApp {
  id            String   @id @default(cuid())
  slug          String   @unique
  name          String
  description   String
  category      String   // finance | utilities | games | shopping | social
  icon          String   // emoji
  color         String   // tailwind gradient class suffix
  developer     String
  rating        Float    @default(4.5)
  installs      Int      @default(0)
  featured      Boolean  @default(false)
  enabled       Boolean  @default(true)
  url           String?  // external link / launch URL
  createdAt     DateTime @default(now())

  @@index([category])
}

model ESimPurchase {
  id           String   @id @default(cuid())
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  countryCode  String
  countryName  String
  flag         String
  planId       String
  planLabel    String
  dataAmount   String   // "1GB" | "5GB" | "10GB" | "Unlimited"
  durationDays Int
  price        Float
  currency     String   @default("USD")
  activationQr String?  // base64-encoded QR payload for eSim activation
  status       String   @default("pending") // pending | active | expired
  activatedAt  DateTime?
  expiresAt    DateTime?
  createdAt    DateTime @default(now())

  @@index([userId])
}

model Pocket {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  code      String   // USDT | USDC | cUSD
  name      String
  balance   Float    @default(0)
  color     String   @default("violet")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, code])
  @@index([userId])
}

// ---------------------------------------------------------------------------
// Savings Challenges — gamified savings with streaks, badges, milestones
// ---------------------------------------------------------------------------

model SavingsChallenge {
  id            String   @id @default(cuid())
  slug          String   @unique
  title         String
  description   String
  icon          String   // emoji
  category      String   // "streak" | "amount" | "behavior" | "roundup"
  targetAmount  Float
  durationDays  Int
  difficulty    String   // "easy" | "medium" | "hard"
  colorFrom     String   // tailwind/hex
  colorTo       String
  badgeBronze   Float    // progress % for bronze badge
  badgeSilver   Float
  badgeGold     Float
  badgePlatinum Float
  participants  UserChallengeParticipation[]
  createdAt     DateTime @default(now())
}

model UserChallengeParticipation {
  id                 String   @id @default(cuid())
  userId             String
  challengeId        String
  status             String   @default("active") // "active" | "completed" | "abandoned"
  currentAmount      Float    @default(0)
  streak             Int      @default(0)
  longestStreak      Int      @default(0)
  lastContributionAt DateTime?
  joinedAt           DateTime @default(now())
  completedAt        DateTime?
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  challenge          SavingsChallenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  contributions      ChallengeContribution[]

  @@unique([userId, challengeId])
  @@index([userId])
  @@index([challengeId])
}

model ChallengeContribution {
  id              String   @id @default(cuid())
  participationId String
  amount          Float
  note            String?
  createdAt       DateTime @default(now())
  participation   UserChallengeParticipation @relation(fields: [participationId], references: [id], onDelete: Cascade)

  @@index([participationId])
}

// ═══════════════════════════════════════════════════════════════════════════
// GAEXCHAT — Social messaging with integrated fintech (Task 21)
// ═══════════════════════════════════════════════════════════════════════════

model Conversation {
  id             String   @id @default(cuid())
  // For 1-to-1 chats: participantAId/participantBId are both set and the
  // @@unique pair is enforced. For group chats: both are null and the
  // `groupId` is set instead.
  participantAId String?
  participantBId String?
  groupId        String?  @unique
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  participantA   User?     @relation("ConvParticipantA", fields: [participantAId], references: [id], onDelete: Cascade)
  participantB   User?     @relation("ConvParticipantB", fields: [participantBId], references: [id], onDelete: Cascade)
  group          ChatGroup? @relation(fields: [groupId], references: [id], onDelete: Cascade)
  messages       Message[]

  @@unique([participantAId, participantBId])
  @@index([participantAId])
  @@index([participantBId])
  @@index([groupId])
  @@index([updatedAt])
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  // Message kind: "text" | "payment" | "request" | "bill" | "split" | "system"
  //   | "voice" | "image" | "video" | "document" | "location" | "contact"
  //   | "scheduled" | "loan" | "invoice"
  kind           String   @default("text")
  // For financial messages, JSON metadata (amount, currency, status, txRef,
  // biller, splits, etc.). For attachments: { url, name, size, mimeType,
  // duration, waveform, lat, lng, contactName, ... }. Null for plain text.
  metadata       String?
  status         String   @default("sent") // "sent" | "delivered" | "read"
  createdAt      DateTime @default(now())

  // ── WhatsApp-style messaging fields ────────────────────────────────────
  // Reply / quote: id of the message this one is replying to.
  replyToId      String?
  // Edited timestamp (null = never edited). Shows "edited" indicator.
  editedAt       DateTime?
  // Soft-delete: "me" = hidden only for the deleter; "all" = hidden for everyone.
  deletedFor     String?  // null | "me" | "all"
  // Pinned to top of the conversation (per-conversation pin).
  pinned         Boolean  @default(false)
  // Reactions: JSON array of { userId, emoji } — e.g. [{"u":"abc","e":"❤️"}]
  reactions      String?
  // Disappearing messages: when this message should auto-expire (null = never).
  expiresAt      DateTime?
  // Forwarded from another conversation (id of original message).
  forwardedFromId String?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation(fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@index([replyToId])
  @@index([pinned, conversationId])
}

// Chat group — a multi-participant conversation (WhatsApp group).
model ChatGroup {
  id           String   @id @default(cuid())
  name         String
  description  String?
  avatar       String?
  createdBy    String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  creator      User     @relation("ChatGroupCreator", fields: [createdBy], references: [id], onDelete: Cascade)
  members      ChatGroupMember[]
  conversation Conversation?

  @@index([createdBy])
}

model ChatGroupMember {
  id        String   @id @default(cuid())
  groupId   String
  userId    String
  role      String   @default("member") // "admin" | "member"
  joinedAt  DateTime @default(now())

  group     ChatGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User      @relation("ChatGroupMemberUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([groupId])
  @@index([userId])
}

// Payment request sent inside a chat (Alice asks Bob for 5000 FCFA).
// One PaymentRequest can generate two chat messages: the request bubble
// (created on POST) and the resolution bubble (created on accept/decline).
model PaymentRequest {
  id             String   @id @default(cuid())
  conversationId String
  requesterId    String   // who asks for the money
  payerId        String   // who is being asked
  amount         Float
  currency       String   @default("NGN")
  note           String?
  status         String   @default("pending") // "pending" | "accepted" | "declined" | "paid"
  // Reference of the transaction created when the payer accepts (null until paid)
  transactionId  String?
  messageId      String?  // the chat message that announced this request
  createdAt      DateTime @default(now())
  resolvedAt     DateTime?

  requester      User     @relation("PaymentRequestRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  payer          User     @relation("PaymentRequestPayer", fields: [payerId], references: [id], onDelete: Cascade)
  transaction    Transaction? @relation("PaymentRequestTransaction", fields: [transactionId], references: [id], onDelete: SetNull)

  @@index([conversationId])
  @@index([payerId, status])
  @@index([requesterId, status])
}

// Group bill split initiated inside a chat. Each split has multiple
// ChatBillSplitShare rows (one per participant). When all shares are paid,
// the split is marked "settled".
model ChatBillSplit {
  id             String   @id @default(cuid())
  conversationId String
  initiatorId    String
  billerName     String
  billerCategory String  @default("general")
  totalAmount    Float
  currency       String  @default("NGN")
  note           String?
  status         String   @default("open") // "open" | "settled" | "cancelled"
  messageId      String?
  createdAt      DateTime @default(now())

  initiator      User     @relation("ChatBillSplitInitiator", fields: [initiatorId], references: [id], onDelete: Cascade)
  shares         ChatBillSplitShare[]

  @@index([conversationId])
  @@index([initiatorId])
}

model ChatBillSplitShare {
  id            String   @id @default(cuid())
  splitId       String
  userId        String
  shareAmount   Float
  status        String   @default("pending") // "pending" | "paid" | "declined"
  paidAt        DateTime?
  transactionId String?

  split         ChatBillSplit @relation(fields: [splitId], references: [id], onDelete: Cascade)
  user          User          @relation("ChatBillSplitShareUser", fields: [userId], references: [id], onDelete: Cascade)
  transaction   Transaction?  @relation("ChatBillSplitShareTransaction", fields: [transactionId], references: [id], onDelete: SetNull)

  @@unique([splitId, userId])
  @@index([splitId])
  @@index([userId, status])
}
