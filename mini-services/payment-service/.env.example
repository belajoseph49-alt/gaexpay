# ============================================================
# GaexPay payment-service — Environment Variables
# ============================================================

PORT=3010
NODE_ENV=development

# ---- Database (PostgreSQL for production, SQLite or Postgres for dev)
DATABASE_URL="postgresql://postgres:password@localhost:5432/gaexpay_payment?schema=public"

# ---- Security & Cryptography
# Reused from the main GaexPay project for JWT verification
GAEXPAY_JWT_SECRET="super_secret_jwt_key_that_is_32_characters_long_min"
# Reused for AES-256-GCM encryption of sensitive database fields
GAEXPAY_ENC_KEY="super_secret_enc_key_that_is_32_characters_long_min"

# ---- CinetPay Credentials
CINETPAY_API_KEY="1234567890.example_apikey"
CINETPAY_SITE_ID="123456"
CINETPAY_SECRET_KEY="example_secret_key"

# Whitelisted IP Addresses for CinetPay Webhooks (comma separated)
CINETPAY_WEBHOOK_IP_WHITELIST="127.0.0.1,::1"

# ---- Internal Services Interconnection
WALLET_SERVICE_URL="http://localhost:3000/api/internal/wallets"
WALLET_SERVICE_API_KEY="internal_shared_secret_key_between_services"
